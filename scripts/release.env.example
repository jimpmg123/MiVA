# Fill this file with your production domains, then run:
#   npm run apply:release-env
#
# That generates apps/desktop/.env.production and prints Railway/Vercel/Google env values.

# Railway API (no trailing slash)
VITE_MIVA_API_URL=https://your-miva-api.up.railway.app

# Vercel web console (no trailing slash)
VITE_WEB_CONSOLE_URL=https://your-vercel-app.vercel.app
MIVA_WEB_ORIGINS=https://your-vercel-app.vercel.app
MIVA_CORS_ORIGINS=https://your-vercel-app.vercel.app,http://127.0.0.1:5173,http://localhost:5173

# Google OAuth web client (same ID for Vercel + Railway)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Web download path (default: bundled installer in public/downloads)
VITE_DESKTOP_DOWNLOAD_URL=/downloads/MiVA-Desktop-setup.exe
