# MiVA Desktop (Tauri) build-time environment
#
# Copy to `.env.production` before `npm run package` for a production installer.

# Cloud API used by desktop sign-in, profile sync, and usage events
VITE_MIVA_API_URL=http://127.0.0.1:4000

# Web console opened from the desktop app (device login + help button)
VITE_WEB_CONSOLE_URL=http://127.0.0.1:5173

# Passed into bundled local-helper during packaging
# MIVA_WEB_ORIGINS=https://your-vercel-domain.vercel.app
