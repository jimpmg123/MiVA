# Copy to demo.env for local development and grading demos.
# Do not commit real API keys.
#
# Desktop packaging copies OPENAI_API_KEY (and OPENAI_DEFAULT_MODEL) from demo.env
# into the bundled local-helper .env. Gemini, Groq, and Hugging Face are not bundled.
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant
