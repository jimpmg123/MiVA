PORT=4000
MIVA_API_PORT=4000
MIVA_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_WORKSPACE_REDIRECT_URI=http://127.0.0.1:4000/workspace/google/callback
GOOGLE_WORKSPACE_SUCCESS_URL=http://127.0.0.1:5173/?workspaceConnected=1

# Supabase PostgreSQL
# Use the direct Supabase database URL for Prisma migrations.
# Use the pooled URL for Railway runtime if connection pooling is needed.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Optional: set to true while debugging Prisma queries locally.
PRISMA_QUERY_LOG=false
