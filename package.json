    "tauri:dev": "npm run dev:app",
    "dev:helper": "node scripts/dev-services.mjs start helper",
    "dev:voice": "node scripts/dev-services.mjs start voice",
    "dev:web": "node scripts/dev-services.mjs start web",
    "dev:api": "node scripts/dev-services.mjs start api",
